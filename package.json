{
  "name": "right-on-commander",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "A vertically scrolling Elite-themed space shooter for web and mobile.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "balance": "vitest run --dir test/balance --passWithNoTests"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "fast-check": "^3.23.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
